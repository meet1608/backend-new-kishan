# ─── Copy this file to .env and fill in your values ───

# Port the server runs on
PORT=5000

# The Gmail address you send FROM (use a dedicated Gmail for this)
GMAIL_USER=your-gmail@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
# Steps: Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# The business email that receives all enquiries
RECIPIENT_EMAIL=royalhume@gmail.com

# Frontend URL for CORS (no trailing slash)
# Development:  http://localhost:5173
# Production:   https://yourdomain.com
FRONTEND_URL=http://localhost:5173
